{
  "Job": {
    "class": "coyote.RtwJob",
    "configuration": {
      "Description": [
        "This is considered good practice for multi-line documentation in JSON.",
        "The description is not used by the framework."
      ],
      "Vault": { "filename": "demo.vault", "password": "[#$env.vault.password#]" },
      "Preprocess": {},
      "Reader": {},
      "Filter": {},
      "Mapper": {},
      "Writer": {},
      "Listener": { "DataProfiler": { "target": "[#$sys.user.dir#][#$sys.file.separator#]dataprofile.txt" } },
      "Postprocess": {}
    }
  },
  "logging": [
    {
      "StandardError": {
        "name": "error",
        "categories": "error, fatal, warn"
      }
    },
    {
      "StandardOutput": {
        "name": "default",
        "categories": "info, notice, debug, trace"
      }
    }
  ]
}
{
  "Job": {
    "class": "coyote.RtwJob",
    "configuration": {
      "name": "Simple",
      "Reader": {
        "class": "StaticReader",
        "fields": {
          "name": "defect_count",
          "value": 6,
          "instance": "My Backlog",
          "help": "The number of active backlog items with the classification of 'defect'",
          "type": "gauge"
        }
      },
      "Writer": [
        { "class": "ConsoleWriter", "format": "json", "indent": true, "enabled": false},
        {
          "class": "JdbcWriter",
          "target": "jdbc:h2:[#$jobdir#]/demodb;MODE=Oracle",
          "table": "user",
          "autocreate": true,
          "driver": "org.h2.Driver",
          "library": "jar:[#FormatSymbol.toFileURI(user.home)#]/Tools/h2/bin/h2-1.4.200.jar!/",
          "username": "sa",
          "password": "",
          "batch": 5
        }
      ]
    }
  },
  "logging": [
    { "StandardError": { "name": "error", "categories": "error, fatal, warn" } },
    { "StandardOutput": { "name": "default", "categories": "info, notice, debug, trace" } }
  ]
}
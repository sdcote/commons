{
  "RtwJob":{

    "Vault": { "filename": "[#$sys.app.home#][#$sys.file.separator#]sdcote.vault", "password": "[#$env.vault.password#]" },

    "Reader" : {
      "class" : "DirectoryReader",
      "directory" : "[#$sys.user.home#][#$sys.file.separator#]Pictures[#$sys.file.separator#]Screenshots",
      "pattern" : ".*"
    },

    "Transform": {
      "FileDateClassifier": {  }
    },

    "Logging": [
      {"StandardError": { "name": "error", "target": "STDERR", "categories": "error, fatal, warn" }},
      {"StandardOutput": { "name": "default", "target": "STDOUT", "categories": "info, notice,debug,trace" }}
    ]

  }

}
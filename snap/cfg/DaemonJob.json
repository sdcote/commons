{
  "name": "DaemonJob",
  "Server": {
    "Port": 8080,
    "Users": {
      "User": {
        "Name": "admin",
        "Password": "adminPassword",
        "Groups": "admin"
      }
    }
  },
  "Job": [
    {
      "name": "DownloadsWatch",
      "class": "RtwJob",
      "repeat": true,
      "Reader": {
        "class": "DirectoryTripwireReader",
        "directory": "/Users/sdcote/Downloads"
      },
      "Writer": {
        "class": "ConsoleWriter",
        "format": "json",
        "indent": true
      }
    },
    {
      "name": "LogWatch",
      "class": "RtwJob",
      "repeat": true,
      "Reader": {
        "class": "DirectoryTripwireReader",
        "directory": "/var/log"
      },
      "Writer": {
        "class": "ConsoleWriter",
        "format": "json",
        "indent": true
      }
    }
  ],
  "logging": [
    { "StandardError": { "name": "error", "categories": "error, fatal, warn" } },
    { "StandardOutput": { "name": "default", "categories": "scheduler" }
    }
  ]
}


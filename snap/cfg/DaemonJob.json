{
  "DaemonJob": {
    "Server": {
      "Port": 8080,
      "Users": {
        "User": {
          "Name": "admin",
          "Password": "adminPassword",
          "Groups": "admin"
        }
      }
    },
    "Job": [
      {
        "RtwJob": {
          "Reader": { "class": "DirectoryTripwireReader", "directory": "/Users/sdcote/Downloads" },
          "Writer": { "class": "ConsoleWriter", "format": "json", "indent": true }
        }
      },
      {
        "RtwJob": {
          "Reader": { "class": "DirectoryTripwireReader", "directory": "/var/log" },
          "Writer": { "class": "ConsoleWriter", "format": "json", "indent": true }
        }
      }
    ],
    "Logging": [
      { "StandardError": { "name": "error", "categories": "error, fatal, warn" } },
      { "StandardOutput": { "name": "default", "categories": "info, notice, debug, trace, scheduler" } }
    ]
  }
}


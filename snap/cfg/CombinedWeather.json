{
  "name": "CombinedWeather",
  "Job": [
    {
      "name": "WeatherForecast",
      "class": "coyote.RtwJob",
      "schedule": {
        "minutes": "*/2"
      },
      "Preprocess": [
        {
          "class": "WebGet",
          "source": "https://api.open-meteo.com/v1/forecast?latitude=40.0205&longitude=-83.1775&current=temperature_2m,weather_code&temperature_unit=fahrenheit",
          "target": "weather_data.json"
        }
      ],
      "Reader": {
        "class": "JsonReader",
        "source": "weather_data.json",
        "selector": "current"
      },
      "Transform": [
        {
          "class": "Timestamp",
          "field": "ObservationTime"
        }
      ],
      "Writer": [
        {
          "class": "CsvWriter",
          "target": "weather_history.csv",
          "append": true,
          "header": true
        }
      ]
    },
    {
      "name": "SpaceWeather",
      "class": "coyote.RtwJob",
      "schedule": {
        "minutes": "*/30"
      },
      "Preprocess": [
        {
          "class": "WebGet",
          "source": "https://services.swpc.noaa.gov/products/noaa-planetary-k-index.json",
          "target": "space_weather.json"
        }
      ],
      "Reader": {
        "class": "JsonReader",
        "source": "space_weather.json",
        "selector": "*"
      },
      "Transform": [
        {
          "class": "Timestamp",
          "field": "ObservationTime"
        }
      ],
      "Writer": [
        {
          "class": "CsvWriter",
          "target": "space_weather_history.csv",
          "append": true,
          "header": true
        }
      ]
    }
  ],
  "logging": [
    {
      "StandardError": {
        "name": "error",
        "categories": "error, fatal, warn"
      }
    },
    {
      "StandardOutput": {
        "name": "default",
        "categories": "info, notice, debug, trace, scheduler"
      }
    },
    {
      "FileAppender": {
        "name": "combined_weather",
        "target": "combined_weather.log",
        "categories": "info, notice, warn, error, fatal"
      }
    }
  ]
}
